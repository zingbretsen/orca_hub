# === Local development (without Docker) ===
DB_USERNAME=orca_hub
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_NAME=orca_hub_dev

# === Docker deployment ===
# These are used by docker-compose.yml. The defaults work out of the box.
# SECRET_KEY_BASE=<run `mix phx.gen.secret` to generate>
# PHX_HOST=localhost
# PORT=4000

# Title generation — uses either OpenAI or DataRobot LLM Gateway.
# If DataRobot credentials are set, they take priority over OpenAI.

# Option 1: OpenAI
# OPENAI_API_KEY=sk-...
# TITLE_MODEL=gpt-4.1-mini

# Option 2: DataRobot LLM Gateway
# DATAROBOT_API_TOKEN=...
# DATAROBOT_ENDPOINT=https://app.datarobot.com
# TITLE_MODEL=azure/gpt-4o-mini
