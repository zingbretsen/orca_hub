# === Local development (without Docker) ===
DB_USERNAME=orca_hub
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_NAME=orca_hub_dev

# === Production release (systemd / `MIX_ENV=prod mix release`) ===
# Required at runtime by config/runtime.exs. The systemd install script
# (systemd/install.sh) pre-flights these before building.
#   SECRET_KEY_BASE — always required. Generate with: mix phx.gen.secret
#   DATABASE_URL    — required UNLESS ORCA_MODE=agent (agents proxy DB ops to the hub).
#                     Format: ecto://USER:PASS@HOST/DATABASE
#   PHX_HOST        — recommended; otherwise the host URL defaults to example.com.
# SECRET_KEY_BASE=<run `mix phx.gen.secret` to generate>
# DATABASE_URL=ecto://orca_hub:postgres@127.0.0.1/orca_hub_prod
# PHX_HOST=localhost
# ORCA_MODE=hub

# === Docker deployment ===
# These are used by docker-compose.yml. The defaults work out of the box.
# SECRET_KEY_BASE=<run `mix phx.gen.secret` to generate>
# PHX_HOST=localhost
# PORT=4000

# Text-to-speech (ElevenLabs)
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
