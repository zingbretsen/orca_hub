<.header>
  Nodes
  <:actions>
    <.button phx-click="show_add_node_form" :if={!@adding_node?} id="add-node">
      Add node
    </.button>
    <.button phx-click="sweep_update_all" disabled={@sweep_active?} id="sweep-update-all">
      {if @sweep_active?, do: "Updating…", else: "Update all backends"}
    </.button>
  </:actions>
</.header>

<div :if={@adding_node?} id="add-node-form" class="card bg-base-200 p-4 mt-4 max-w-lg">
  <.form for={@add_node_form} phx-change="validate_add_node" phx-submit="save_add_node">
    <.input
      field={@add_node_form[:name]}
      label="Node name"
      placeholder="orca@my-laptop"
      autocomplete="off"
    />
    <p class="text-xs text-base-content/50 -mt-3 mb-3">
      The Erlang node name this machine will run as (basename@host).
    </p>
    <.input field={@add_node_form[:display_name]} label="Display name (optional)" />
    <.input
      field={@add_node_form[:dial]}
      type="checkbox"
      label="Hub dials this node (Node.connect every 5s)"
    />
    <div class="flex gap-2 mt-4">
      <.button type="submit">Add</.button>
      <.button type="button" phx-click="cancel_add_node_form" class="btn-ghost">
        Cancel
      </.button>
    </div>
  </.form>
</div>

<.table
  id="nodes"
  rows={@nodes}
  row_click={fn %{node: n} -> JS.navigate(~p"/nodes/#{n.id}") end}
>
  <:col :let={%{node: n}} label="Name">
    <div class="font-medium flex items-center gap-2">
      {n.display_name}
      <span
        :if={n.isolated}
        class="badge badge-xs badge-warning"
        title="Cross-node MCP tools are blocked on this node"
      >
        isolated
      </span>
      <span
        :if={n.scrub_session_env}
        class="badge badge-xs badge-warning"
        title="Sessions/terminals on this node run with a minimal allow-list environment"
      >
        scrubbed env
      </span>
      <span
        :if={n.dial}
        class="badge badge-xs badge-info"
        title="The hub dials this node every 5s (OrcaHub.NodeDialer)"
      >
        dials
      </span>
      <span
        :if={n.default_backend || n.default_model}
        class="badge badge-xs badge-ghost"
        title="Default backend/model applied to sessions created on this node"
      >
        default: {n.default_backend || "claude"}{if n.default_model, do: " / #{n.default_model}"}
      </span>
    </div>
    <div class="text-xs text-base-content/60 font-mono">{n.name}</div>
  </:col>
  <:col :let={%{connected: connected?}} label="Status">
    <span class={["badge", if(connected?, do: "badge-success", else: "badge-neutral")]}>
      {if connected?, do: "connected", else: "offline"}
    </span>
  </:col>
  <:col :let={%{node: n, connected: connected?}} label="Last Connected">
    {last_connected_label(connected?, n.last_connected_at)}
  </:col>
  <:col :let={%{session_count: count}} label="Sessions">{count}</:col>
  <:col :let={%{project_count: count}} label="Projects">{count}</:col>
</.table>

<p :if={@nodes == []} class="text-sm text-base-content/60 mt-4">
  No nodes have connected to this cluster yet.
</p>

<div :if={@sweep_active? or @sweep_summary} class="mt-6" id="backend-sweep">
  <h3 class="font-semibold mb-2">Backend update sweep</h3>

  <p :if={@sweep_summary} id="backend-sweep-summary" class="text-sm mb-2">
    {@sweep_summary}
  </p>

  <div class="overflow-x-auto">
    <table class="table table-sm">
      <thead>
        <tr>
          <th>Node</th>
          <th :for={backend <- backends()} class="capitalize">{backend}</th>
        </tr>
      </thead>
      <tbody>
        <tr
          :for={row <- @nodes}
          :if={MapSet.member?(@sweep_node_names, row.node.name)}
          id={"backend-sweep-row-#{row.node.id}"}
        >
          <td class="font-medium">{row.node.display_name}</td>
          <td :for={backend <- backends()} id={"backend-sweep-cell-#{row.node.id}-#{backend}"}>
            <% sweep_cell = Map.get(@sweep_cells, {row.node.name, backend}) %>
            <div :if={sweep_cell} class="flex items-center gap-1.5">
              <span
                :if={sweep_cell.status == :running}
                class="loading loading-spinner loading-xs"
              />
              <span :if={sweep_cell.status == :pending} class="text-xs text-base-content/50">
                pending…
              </span>
              <span :if={sweep_cell.status == :running} class="text-xs">
                running{if sweep_cell.output_tail != "", do: " — #{sweep_cell.output_tail}"}
              </span>
              <span :if={sweep_cell.status == :done} class="badge badge-xs badge-success">
                done — {sweep_cell.version || "unknown version"}
              </span>
              <span
                :if={sweep_cell.status == :failed}
                class="badge badge-xs badge-error"
                title={sweep_cell.reason}
              >
                failed — {sweep_cell.reason}
              </span>
              <span
                :if={sweep_cell.status == :skipped}
                class="badge badge-xs badge-ghost"
                title={sweep_cell.reason}
              >
                skipped — {sweep_cell.reason}
              </span>
            </div>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</div>
