<div :if={!@connected} id="node-unavailable" class="alert alert-warning mb-2">
  <.icon name="hero-signal-slash" class="size-5" />
  <span>
    This node is not currently connected. Node-local operations are unavailable until it reconnects.
  </span>
</div>

<.header>
  <.link navigate={~p"/nodes"} class="text-sm opacity-70">&larr; Nodes</.link>
  <span class="ml-2">{@node.display_name}</span>
</.header>

<div class="card bg-base-200 p-4 mt-4">
  <.list>
    <:item title="Status">
      <span class={["badge", if(@connected, do: "badge-success", else: "badge-neutral")]}>
        {if @connected, do: "connected", else: "offline"}
      </span>
    </:item>
    <:item title="Node name"><span class="font-mono">{@node.name}</span></:item>
    <:item title="Display name">{@node.display_name}</:item>
    <:item title="First connected">{first_connected_label(@node.first_connected_at)}</:item>
    <:item title="Last connected">
      {last_connected_label(@connected, @node.last_connected_at)}
    </:item>
    <:item title="Sessions">{@session_count}</:item>
    <:item title="Projects">{@project_count}</:item>
    <:item title="Isolated">
      <label class="label cursor-pointer gap-2 justify-start">
        <input
          type="checkbox"
          class="toggle toggle-xs"
          checked={@node.isolated}
          phx-click="toggle_isolated"
        />
        <span class="label-text text-xs">
          Sessions on this node cannot message, inspect, or spawn sessions on other nodes, and session search is scoped to this node.
        </span>
      </label>
    </:item>
    <:item title="Hub dials this node">
      <label class="label cursor-pointer gap-2 justify-start">
        <input
          type="checkbox"
          class="toggle toggle-xs"
          checked={@node.dial}
          phx-click="toggle_dial"
        />
        <span class="label-text text-xs">
          The hub actively Node.connect/1's this node every 5s (OrcaHub.NodeDialer) — for LAN nodes the pod network can't dial into, only out of.
        </span>
      </label>
    </:item>
    <:item title="Scrub session env">
      <label class="label cursor-pointer gap-2 justify-start">
        <input
          type="checkbox"
          class="toggle toggle-xs"
          checked={@node.scrub_session_env}
          phx-click="toggle_scrub_session_env"
        />
        <span class="label-text text-xs">
          Sessions and terminals on this node run with a minimal allow-list environment (PATH/HOME/TERM/locale + backend API keys); pod/host secrets are not inherited.
        </span>
      </label>
    </:item>
    <:item :if={@node.scrub_session_env} title="Env allow-list">
      <form phx-submit="update_env_allowlist">
        <input
          type="text"
          name="env_allowlist"
          value={OrcaHubWeb.EnvAllowlistInput.to_text(@node.env_allowlist)}
          placeholder="AWS_*, MY_TOKEN"
          class="input input-bordered input-sm w-full max-w-md font-mono"
        />
        <button type="submit" class="btn btn-sm btn-ghost">Save</button>
      </form>
      <p class="text-xs text-base-content/50 mt-1">
        Extra variable names (comma/space/newline separated) additionally kept, on top of the base allow-list, while "Scrub session env" above is ON. End an entry in
        <code>*</code>
        for a prefix match, e.g. <code>AWS_*</code>
        matches any <code>AWS_...</code>
        variable. Combined with this project's own env allow-list, if the session belongs to one. Has no effect while "Scrub session env" is off.
      </p>
    </:item>
    <:item title="Default backend">
      <form phx-change="update_default_backend">
        <select name="default_backend" class="select select-bordered select-sm">
          <option value="" selected={@node.default_backend in [nil, ""]}>(no default)</option>
          <option
            :for={{value, label} <- default_backend_options(@connected, @config_node)}
            value={value}
            selected={@node.default_backend == value}
          >
            {label}
          </option>
        </select>
      </form>
      <p class="text-xs text-base-content/50 mt-1">
        New sessions created on this node default to this backend when the caller doesn't specify one.
      </p>
    </:item>
    <:item title="Default model">
      <% model_options = default_model_options(@node, @connected, @config_node) %>
      <form :if={model_options != []} phx-change="update_default_model">
        <select name="default_model" class="select select-bordered select-sm">
          <option value="" selected={@node.default_model in [nil, ""]}>(no default)</option>
          <option
            :for={{id, label} <- model_options}
            value={id}
            selected={@node.default_model == id}
          >
            {label}
          </option>
        </select>
      </form>
      <form :if={model_options == []} phx-change="update_default_model">
        <input
          type="text"
          name="default_model"
          value={@node.default_model}
          phx-debounce="blur"
          placeholder="(no default)"
          class="input input-bordered input-sm w-full max-w-xs font-mono"
        />
      </form>
      <p class="text-xs text-base-content/50 mt-1">
        New sessions created on this node default to this model when the caller doesn't specify one. Only applied when the session's effective backend matches the default backend above.
      </p>
    </:item>
  </.list>
</div>

<div class="mt-6">
  <h3 class="font-semibold mb-2">Backends</h3>

  <div class="flex items-center gap-2 mb-3 flex-wrap">
    <span
      :if={@claude_logged_in?}
      class="badge badge-sm badge-info gap-1"
      title="A Claude Code OAuth token is stored for this node"
    >
      <.icon name="hero-key-micro" class="size-3" /> claude: logged in
    </span>
    <button
      :if={@connected}
      phx-click="login_node"
      class="btn btn-xs btn-ghost"
      title="Log this node into Claude Code"
    >
      <.icon name="hero-arrow-right-on-rectangle-micro" class="size-4" /> Claude login
    </button>
    <button
      :if={@claude_logged_in?}
      phx-click="logout_node"
      data-confirm={"Remove the stored Claude Code token for #{@node.display_name}?"}
      class="btn btn-xs btn-ghost text-warning"
      title="Remove stored credential"
    >
      <.icon name="hero-trash-micro" class="size-4" /> Remove credential
    </button>
  </div>

  <div
    :if={!@connected}
    id="backend-installer-node-unavailable"
    class="text-sm text-base-content/50 p-4 text-center bg-base-200 rounded-lg"
  >
    Node unavailable — install/update requires an active connection to this node.
  </div>

  <div :if={@connected} class="space-y-3" id="backend-installer-sections">
    <div
      :for={row <- @backend_installer_status || []}
      id={"backend-installer-#{row.backend}"}
      class="card bg-base-200 p-4"
    >
      <div class="flex items-center justify-between gap-3 flex-wrap">
        <div class="flex items-center gap-2 flex-wrap">
          <span class="font-semibold text-sm capitalize">{row.backend}</span>
          <span class="text-sm font-mono opacity-70">
            {if row.installed?, do: row.version || "unknown version", else: "not installed"}
          </span>
          <span
            :if={row.installed? && row.latest_version && row.latest_version != row.version}
            class="badge badge-xs badge-info"
          >
            update available: {row.latest_version}
          </span>
          <span
            :if={row.ephemeral?}
            class="badge badge-xs badge-warning"
            title="Binary lives in the container's writable layer, not the PVC — reverts on pod restart"
          >
            ephemeral (pod)
          </span>
        </div>

        <div class="flex items-center gap-2">
          <span
            :if={MapSet.member?(@backend_installer_running, row.backend)}
            class="loading loading-spinner loading-xs"
          />
          <button
            :if={
              row.action != :unavailable &&
                !MapSet.member?(@backend_installer_running, row.backend)
            }
            phx-click="run_backend_job"
            phx-value-backend={row.backend}
            phx-value-action={row.action}
            class="btn btn-xs btn-primary"
          >
            {if row.action == :install, do: "Install", else: "Update"}
          </button>
          <span
            :if={row.action == :unavailable}
            class="badge badge-xs badge-ghost"
            title={row.unavailable_reason}
          >
            unavailable
          </span>
        </div>
      </div>

      <div :if={row.ephemeral?} class="text-xs text-warning mt-2">
        Changes revert on pod restart — durable updates require an image rebuild.
      </div>

      <div :if={row.action == :unavailable} class="text-xs text-base-content/50 mt-2">
        {row.unavailable_reason}
      </div>

      <pre
        :if={Map.get(@backend_installer_output, row.backend, "") != ""}
        id={"backend-installer-output-#{row.backend}"}
        class="mt-2 bg-base-300 text-xs p-2 rounded max-h-40 overflow-y-auto whitespace-pre-wrap"
      >{Map.get(@backend_installer_output, row.backend, "")}</pre>

      <div :if={result = Map.get(@backend_installer_result, row.backend)} class="text-xs mt-2">
        <span :if={match?({:ok, _}, result)} class="text-success">
          Done — now at {elem(result, 1) || "unknown version"}
        </span>
        <span :if={match?({:error, _}, result)} class="text-error">
          Failed: {inspect(elem(result, 1))}
        </span>
      </div>

      <div
        :if={row.backend == :codex}
        class="flex items-center gap-2 mt-3 pt-3 border-t border-base-300 flex-wrap"
      >
        <span
          :if={@codex_status.status != :not_logged_in}
          class="badge badge-xs badge-secondary gap-1"
          title="Codex login status"
        >
          <.icon name="hero-key-micro" class="size-3" /> codex: {@codex_status.label}
        </span>
        <span
          :if={@codex_env_conflict?}
          class="badge badge-xs badge-warning gap-1"
          title="OPENAI_API_KEY is set on this node and will override any codex login"
        >
          <.icon name="hero-exclamation-triangle-micro" class="size-3" /> codex env conflict
        </span>
        <button
          phx-click="codex_login_device"
          class="btn btn-xs btn-ghost"
          title="Log this node into codex via ChatGPT device-auth"
        >
          <.icon name="hero-arrow-right-on-rectangle-micro" class="size-4" /> Login (device)
        </button>
        <button
          phx-click="codex_login_api_key_open"
          class="btn btn-xs btn-ghost"
          title="Set a codex API key for this node"
        >
          <.icon name="hero-key-micro" class="size-4" /> API key
        </button>
      </div>

      <div
        :if={row.backend == :pi}
        class="flex items-center gap-2 mt-3 pt-3 border-t border-base-300 flex-wrap"
      >
        <span
          :if={@pi_providers != []}
          class="badge badge-xs badge-accent gap-1"
          title="Configured pi provider keys"
        >
          <.icon name="hero-key-micro" class="size-3" /> pi: {length(@pi_providers)}
        </span>
        <button
          phx-click="open_pi_keys"
          class="btn btn-xs btn-ghost"
          title="Manage pi provider keys for this node"
        >
          <.icon name="hero-key-micro" class="size-4" /> Manage keys
        </button>
      </div>
    </div>
  </div>
</div>

<div class="mt-6">
  <h3 class="font-semibold mb-2">Backend Configuration</h3>

  <div
    :if={!@connected}
    id="backend-config-node-unavailable"
    class="text-sm text-base-content/50 p-4 text-center bg-base-200 rounded-lg"
  >
    Node unavailable — backend configuration requires an active connection to this node.
  </div>

  <div :if={@connected} class="space-y-4" id="backend-config-sections">
    <div
      :for={backend <- OrcaHub.NodeConfig.backends()}
      id={"config-section-#{backend}"}
      class="card bg-base-200"
    >
      <% result = @node_config[backend] %>

      <div
        class="flex items-center justify-between px-4 py-3 cursor-pointer"
        phx-click="toggle_config_section"
        phx-value-backend={backend}
      >
        <div class="flex items-center gap-2">
          <.icon
            name={
              if MapSet.member?(@config_sections_expanded, backend),
                do: "hero-chevron-down-micro",
                else: "hero-chevron-right-micro"
            }
            class="size-4"
          />
          <span class="font-semibold text-sm capitalize">{backend}</span>
          <span :if={match?(%{}, result) && !result.installed?} class="badge badge-xs badge-ghost">
            not installed on this node
          </span>
          <span
            :if={backend == :codex && match?(%{}, result) && result.agents_override_conflict?}
            class="badge badge-xs badge-warning"
            title="AGENTS.override.md replaces AGENTS.md entirely for this node's sessions"
          >
            AGENTS.override.md active
          </span>
        </div>
      </div>

      <div
        :if={MapSet.member?(@config_sections_expanded, backend) && match?({:error, _}, result)}
        class="px-4 pb-4 text-sm text-error"
      >
        Failed to load: {elem(result, 1) |> inspect()}
      </div>

      <div
        :if={MapSet.member?(@config_sections_expanded, backend) && match?(%{}, result)}
        class="px-4 pb-4 space-y-2"
      >
        <div :for={entry <- result.entries} id={"config-entry-#{backend}-#{entry.path}"}>
          <%= if entry.kind == :file do %>
            <.config_file_row
              backend={backend}
              entry={entry}
              config_expanded={@config_expanded}
              config_editing={@config_editing}
              config_edit_content={@config_edit_content}
              config_content={@config_content}
              editing_block={@editing_block}
              block_edit_content={@block_edit_content}
              config_view_mode={@config_view_mode}
              structured_editing={@structured_editing}
              structured_edit_value={@structured_edit_value}
            />
          <% else %>
            <.config_dir_row
              backend={backend}
              entry={entry}
              config_dirs_expanded={@config_dirs_expanded}
              config_expanded={@config_expanded}
              config_editing={@config_editing}
              config_edit_content={@config_edit_content}
              config_content={@config_content}
              config_new_entry={@config_new_entry}
              config_new_entry_name={@config_new_entry_name}
              config_new_entry_content={@config_new_entry_content}
              editing_block={@editing_block}
              block_edit_content={@block_edit_content}
              config_view_mode={@config_view_mode}
              structured_editing={@structured_editing}
              structured_edit_value={@structured_edit_value}
              managed_skills={Map.get(@managed_skills, backend, MapSet.new())}
            />
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<%!-- Node login flow (claude setup-token) --%>
<div
  :if={@login_node}
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
  phx-window-keydown="cancel_login"
  phx-key="escape"
>
  <div class="bg-base-100 rounded-lg shadow-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between px-5 py-3 border-b border-base-300">
      <h3 class="text-lg font-semibold">
        Log in {Cluster.node_name(@login_node)}
      </h3>
      <button phx-click="cancel_login" class="btn btn-sm btn-ghost btn-circle">
        <.icon name="hero-x-mark-micro" class="size-4" />
      </button>
    </div>

    <div class="px-5 py-4 space-y-4">
      <%= case @login_status do %>
        <% :success -> %>
          <div class="alert alert-success text-sm">
            <.icon name="hero-check-circle-micro" class="size-5" />
            <span>{Cluster.node_name(@login_node)} is now logged in to Claude Code.</span>
          </div>
        <% :error -> %>
          <div class="alert alert-error text-sm">
            <.icon name="hero-exclamation-triangle-micro" class="size-5" />
            <span>Login failed: {@login_error}</span>
          </div>
        <% _ -> %>
          <p class="text-sm text-base-content/70">
            Open the authorize URL below, sign in, then paste the resulting code here.
          </p>
      <% end %>

      <div :if={@login_url && @login_status != :success}>
        <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wide mb-1">
          Authorize URL
        </div>
        <a
          href={@login_url}
          target="_blank"
          rel="noopener"
          class="link link-primary text-sm break-all"
        >
          {@login_url}
        </a>
      </div>

      <form
        :if={@login_status not in [:success, :error]}
        phx-submit="submit_login_code"
        class="flex items-end gap-2"
      >
        <div class="flex-1">
          <label class="text-xs font-semibold text-base-content/50 uppercase tracking-wide">
            Paste code
          </label>
          <input
            type="text"
            name="code"
            autocomplete="off"
            placeholder="Paste the code from the browser"
            class="input input-bordered input-sm w-full mt-1"
          />
        </div>
        <button type="submit" class="btn btn-sm btn-primary">Submit</button>
      </form>

      <div>
        <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wide mb-1">
          Output
        </div>
        <pre class="bg-base-300 rounded p-3 text-xs overflow-x-auto max-h-64 whitespace-pre-wrap">{if @login_output == "", do: "Starting…", else: @login_output}</pre>
      </div>

      <div class="flex justify-end gap-2 pt-2">
        <button
          :if={@login_status in [:success, :error]}
          phx-click="close_login"
          class="btn btn-sm btn-primary"
        >
          Close
        </button>
        <button
          :if={@login_status not in [:success, :error]}
          phx-click="cancel_login"
          class="btn btn-sm btn-ghost"
        >
          Cancel
        </button>
      </div>
    </div>
  </div>
</div>

<%!-- Node login flow (codex device-auth / API key) --%>
<div
  :if={@codex_login_node}
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
  phx-window-keydown="cancel_codex_login"
  phx-key="escape"
>
  <div class="bg-base-100 rounded-lg shadow-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between px-5 py-3 border-b border-base-300">
      <h3 class="text-lg font-semibold">
        Log in {Cluster.node_name(@codex_login_node)} to codex
        <span class="text-sm font-normal text-base-content/50">
          ({if @codex_login_mode == :device_auth, do: "device auth", else: "API key"})
        </span>
      </h3>
      <button phx-click="cancel_codex_login" class="btn btn-sm btn-ghost btn-circle">
        <.icon name="hero-x-mark-micro" class="size-4" />
      </button>
    </div>

    <div class="px-5 py-4 space-y-4">
      <div :if={@codex_env_conflict?} class="alert alert-warning text-sm">
        <.icon name="hero-exclamation-triangle-micro" class="size-5" />
        <span>
          <code class="bg-base-300 px-1 rounded">OPENAI_API_KEY</code>
          is set on this node's environment and will silently override this login for codex —
          unset it there first if you want this login to actually take effect.
        </span>
      </div>

      <%= case @codex_login_status do %>
        <% :success -> %>
          <div class="alert alert-success text-sm">
            <.icon name="hero-check-circle-micro" class="size-5" />
            <span>{Cluster.node_name(@codex_login_node)} is now logged in to codex.</span>
          </div>
        <% :error -> %>
          <div class="alert alert-error text-sm">
            <.icon name="hero-exclamation-triangle-micro" class="size-5" />
            <span>Login failed: {@codex_login_error}</span>
          </div>
        <% _ -> %>
          <p :if={@codex_login_mode == :device_auth} class="text-sm text-base-content/70">
            Open the verification URL below on <strong>any</strong>
            device, sign in, and enter the code shown — no need to paste anything back here.
            Requires "device code" login to be enabled in your ChatGPT account's security
            settings first.
          </p>
          <p :if={@codex_login_mode == :api_key} class="text-sm text-base-content/70">
            Paste an OpenAI API key below. It's piped directly to
            <code class="bg-base-300 px-1 rounded">codex login --with-api-key</code>
            on the target node and is never stored, logged, or displayed by OrcaHub.
            This is API-key auth only — it does not grant ChatGPT-plan usage.
          </p>
      <% end %>

      <div :if={
        @codex_login_mode == :device_auth && @codex_login_url && @codex_login_status != :success
      }>
        <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wide mb-1">
          Verification URL
        </div>
        <a
          href={@codex_login_url}
          target="_blank"
          rel="noopener"
          class="link link-primary text-sm break-all"
        >
          {@codex_login_url}
        </a>
      </div>

      <div :if={
        @codex_login_mode == :device_auth && @codex_login_code && @codex_login_status != :success
      }>
        <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wide mb-1">
          Code
        </div>
        <div class="text-lg font-mono tracking-widest">{@codex_login_code}</div>
      </div>

      <form
        :if={
          @codex_login_mode == :api_key && @codex_login_status not in [:running, :success, :error]
        }
        phx-submit="submit_codex_api_key"
        class="flex items-end gap-2"
      >
        <div class="flex-1">
          <label class="text-xs font-semibold text-base-content/50 uppercase tracking-wide">
            API key
          </label>
          <input
            type="password"
            name="key"
            autocomplete="off"
            placeholder="sk-..."
            class="input input-bordered input-sm w-full mt-1"
          />
        </div>
        <button type="submit" class="btn btn-sm btn-primary">Log in</button>
      </form>

      <div :if={@codex_login_mode == :device_auth}>
        <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wide mb-1">
          Output
        </div>
        <pre class="bg-base-300 rounded p-3 text-xs overflow-x-auto max-h-64 whitespace-pre-wrap">{if @codex_login_output == "", do: "Starting…", else: @codex_login_output}</pre>
      </div>

      <div :if={@codex_login_mode == :api_key && @codex_login_status == :running} class="text-sm">
        <span class="loading loading-spinner loading-sm"></span>
        Running codex login --with-api-key…
      </div>

      <div class="flex justify-end gap-2 pt-2">
        <button
          :if={@codex_login_status in [:success, :error]}
          phx-click="close_codex_login"
          class="btn btn-sm btn-primary"
        >
          Close
        </button>
        <button
          :if={@codex_login_status not in [:success, :error]}
          phx-click="cancel_codex_login"
          class="btn btn-sm btn-ghost"
        >
          Cancel
        </button>
      </div>
    </div>
  </div>
</div>

<%!-- pi provider keys --%>
<div
  :if={@pi_key_node}
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
  phx-window-keydown="close_pi_keys"
  phx-key="escape"
>
  <div class="bg-base-100 rounded-lg shadow-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between px-5 py-3 border-b border-base-300">
      <h3 class="text-lg font-semibold">
        pi provider keys — {Cluster.node_name(@pi_key_node)}
      </h3>
      <button phx-click="close_pi_keys" class="btn btn-sm btn-ghost btn-circle">
        <.icon name="hero-x-mark-micro" class="size-4" />
      </button>
    </div>

    <div class="px-5 py-4 space-y-4">
      <p class="text-sm text-base-content/70">
        Keys are written directly to
        <code class="bg-base-300 px-1 rounded">~/.pi/agent/auth.json</code>
        on the target node — write-only, never displayed again here. Unlike codex (where an
        env var wins), pi prefers a stored <code class="bg-base-300 px-1 rounded">auth.json</code>
        key <strong>over</strong>
        any environment variable of the same provider.
      </p>

      <form phx-submit="save_pi_key" class="card bg-base-200 p-3 space-y-2" phx-value-provider="">
        <div class="flex items-end gap-2">
          <div class="flex-1">
            <label class="label"><span class="label-text text-xs">Provider</span></label>
            <select name="provider" class="select select-bordered select-sm w-full">
              <option :for={p <- @pi_provider_options} value={p}>{p}</option>
              <option value="custom">custom…</option>
            </select>
          </div>
          <div class="flex-1">
            <label class="label">
              <span class="label-text text-xs">Custom provider id</span>
            </label>
            <input
              type="text"
              name="custom_provider"
              placeholder="only used if 'custom' is selected"
              class="input input-sm input-bordered w-full"
            />
          </div>
        </div>
        <div class="flex items-end gap-2">
          <div class="flex-1">
            <label class="label"><span class="label-text text-xs">API key</span></label>
            <input
              type="password"
              name="key"
              autocomplete="off"
              class="input input-sm input-bordered w-full"
            />
          </div>
          <.button type="submit" class="btn-sm">Save</.button>
        </div>
      </form>

      <div
        :if={@pi_key_sanity}
        class={[
          "alert text-xs",
          if(match?({:ok, _}, @pi_key_sanity), do: "alert-success", else: "alert-warning")
        ]}
      >
        <span>{elem(@pi_key_sanity, 1)}</span>
      </div>

      <div>
        <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wide mb-1">
          Configured providers
        </div>
        <div
          :if={@pi_providers == []}
          class="text-sm text-base-content/50 p-4 text-center bg-base-200 rounded-lg"
        >
          No pi provider keys configured on this node.
        </div>
        <div
          :if={@pi_providers != []}
          class="bg-base-200 rounded-lg divide-y divide-base-300 overflow-hidden"
        >
          <div :for={p <- @pi_providers} class="flex items-center gap-3 px-3 py-2 text-sm">
            <div class="flex-1">
              <span class="font-mono">{p.provider}</span>
              <span class="badge badge-xs badge-success ml-2">configured</span>
              <span :if={p.type} class="text-xs text-base-content/50 ml-1">({p.type})</span>
            </div>
            <button
              phx-click="delete_pi_key"
              phx-value-provider={p.provider}
              data-confirm={"Remove the stored #{p.provider} key on #{Cluster.node_name(@pi_key_node)}?"}
              class="btn btn-xs btn-ghost text-error"
              title="Remove"
            >
              <.icon name="hero-trash-micro" class="size-4" />
            </button>
          </div>
        </div>
      </div>

      <div class="flex justify-end pt-2">
        <button phx-click="close_pi_keys" class="btn btn-sm btn-primary">Close</button>
      </div>
    </div>
  </div>
</div>
