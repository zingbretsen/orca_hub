<div
  id="drop-target"
  phx-hook="DropTarget"
  class="relative flex flex-col h-[calc(100vh-6rem)] sm:h-[calc(100vh-8rem)]"
  style={if @open_files != [] || @show_file_browser || @show_terminal, do: "margin-left: calc(-50vw + 50%); width: 100vw; padding-left: 2rem; padding-right: 2rem;"}
>
  <div data-drop-overlay class="hidden absolute inset-0 z-50 bg-base-300/80 rounded-lg flex items-center justify-center pointer-events-none">
    <div class="border-2 border-dashed border-primary rounded-xl p-8 text-center">
      <.icon name="hero-arrow-down-tray" class="size-8 text-primary mb-2" />
      <p class="text-lg font-medium text-primary">Drop files here</p>
    </div>
  </div>

  <.header>
    <.link navigate={~p"/sessions"} class="text-sm opacity-70">&larr; Sessions</.link>
    <%= if @editing_title do %>
      <form phx-submit="save_title" class="inline-flex items-center gap-1 ml-2">
        <input
          type="text"
          name="title"
          value={@session.title || ""}
          placeholder="Session title"
          class="input input-sm input-bordered w-64"
          autofocus
          phx-key="Escape"
          phx-keydown="cancel_title_edit"
        />
        <button type="submit" class="btn btn-ghost btn-sm btn-circle" title="Save">
          <.icon name="hero-check-micro" class="size-4" />
        </button>
        <button type="button" phx-click="cancel_title_edit" class="btn btn-ghost btn-sm btn-circle" title="Cancel">
          <.icon name="hero-x-mark-micro" class="size-4" />
        </button>
      </form>
    <% else %>
      <span class="ml-2 cursor-pointer hover:underline group" phx-click="edit_title" title="Click to edit title">
        {@session.title || @session.directory}
        <.icon name="hero-pencil-micro" class="size-3 opacity-0 group-hover:opacity-50 inline" />
      </span>
    <% end %>
    <span class={[
      "badge ml-2",
      @status == :running && "badge-warning",
      @status == :compacting && "badge-warning",
      @status == :waiting && "badge-info",
      @status == :idle && "badge-success",
      @status == :ready && "badge-ghost",
      @status == :error && "badge-error"
    ]}>
      {@status}
    </span>
    <span :if={@remote_session && length(Node.list()) > 0} class="badge badge-ghost badge-outline ml-1" title={inspect(@session_node)}>
      {OrcaHub.Cluster.node_name(@session_node)}
    </span>
    <span :if={@plan_mode == :planning} class="badge badge-warning badge-outline ml-1">planning</span>
    <span :if={@plan_mode == :review} class="badge badge-info badge-outline ml-1">needs review</span>
    <:subtitle>
      <.link :if={@session.project} navigate={~p"/projects/#{@session.project}"} class="hover:underline">
        {@session.project.name}
      </.link>
      <span :if={@session.project} class="text-base-content/40 ml-1">{@session.directory}</span>
      <span :if={!@session.project}>{@session.directory}</span>
    </:subtitle>
    <:actions>
      <div class="dropdown dropdown-end">
        <div tabindex="0" role="button" class="btn btn-ghost btn-sm gap-1" title="Model">
          <.icon name="hero-cpu-chip" class="size-4" />
          <span class="text-xs hidden sm:inline">{@session.model || "default"}</span>
        </div>
        <ul tabindex="0" class="dropdown-content menu bg-base-300 rounded-box z-10 w-52 p-2 shadow-lg">
          <li><button phx-click="set_model" phx-value-model="" class={[@session.model == nil && "active"]}>Default</button></li>
          <li><button phx-click="set_model" phx-value-model="claude-opus-4-6" class={[@session.model == "claude-opus-4-6" && "active"]}>Opus 4.6</button></li>
          <li><button phx-click="set_model" phx-value-model="claude-sonnet-4-6" class={[@session.model == "claude-sonnet-4-6" && "active"]}>Sonnet 4.6</button></li>
          <li><button phx-click="set_model" phx-value-model="claude-haiku-4-5-20251001" class={[@session.model == "claude-haiku-4-5-20251001" && "active"]}>Haiku 4.5</button></li>
        </ul>
      </div>
      <button :if={@todos != []} phx-click="toggle_todos" class={["btn btn-ghost btn-sm btn-circle indicator", @show_todos && "text-primary"]} title="Tasks">
        <.icon name="hero-clipboard-document-check" class="size-5" />
        <span class="indicator-item badge badge-xs badge-primary">
          {Enum.count(@todos, & &1["status"] == "completed")}/{length(@todos)}
        </span>
      </button>
      <button :if={@commits != []} phx-click="toggle_commits" class={["btn btn-ghost btn-sm btn-circle indicator", @show_commits && "text-primary"]} title="Commits">
        <.icon name="hero-code-bracket" class="size-5" />
        <span class="indicator-item badge badge-xs badge-primary">{length(@commits)}</span>
      </button>
      <button phx-click="regenerate_title" class="btn btn-ghost btn-sm btn-circle" title="Regenerate title">
        <.icon name="hero-sparkles" class="size-5" />
      </button>
      <button phx-click="toggle_file_browser" class={["btn btn-ghost btn-sm btn-circle", (@open_files != [] || @show_file_browser) && "text-primary"]} title="Browse files">
        <.icon name="hero-document-text" class="size-5" />
      </button>
      <button phx-click="open_terminal" class={["btn btn-ghost btn-sm btn-circle", @show_terminal && "text-primary"]} title="Open terminal">
        <.icon name="hero-command-line" class="size-5" />
      </button>
      <button
        :if={@session.claude_session_id}
        phx-click="resume_in_terminal"
        class="btn btn-ghost btn-sm btn-circle"
        title="Resume Claude in terminal"
      >
        <.icon name="hero-play" class="size-5" />
      </button>
      <button phx-click="toggle_mcp_modal" class={["btn btn-ghost btn-sm btn-circle", @show_mcp_modal && "text-primary"]} title="MCP servers">
        <.icon name="hero-server-stack" class="size-5" />
      </button>
      <button
        :if={@session.claude_session_id}
        id="copy-terminal-cmd"
        phx-hook="CopyToClipboard"
        data-copy-text={"cd #{@session.directory} && claude --resume #{@session.claude_session_id}"}
        class="btn btn-ghost btn-sm btn-circle"
        title="Copy CLI resume command"
      >
        <.icon name="hero-clipboard" class="size-5" />
      </button>
      <button :if={@session.archived_at} phx-click="unarchive" class="btn btn-ghost btn-sm btn-circle" title="Unarchive session">
        <.icon name="hero-archive-box-arrow-down" class="size-5" />
      </button>
      <button :if={!@session.archived_at} phx-click="archive" class="btn btn-ghost btn-sm btn-circle" title="Archive session">
        <.icon name="hero-archive-box" class="size-5" />
      </button>
    </:actions>
  </.header>

  <div :if={@commits != [] && @show_commits} class="mb-2 bg-base-200 rounded-lg px-3 py-2">
    <ul class="space-y-1">
      <li :for={commit <- @commits}>
        <button phx-click="toggle_commit_detail" phx-value-hash={commit.hash} class="flex items-start gap-2 text-sm w-full text-left hover:bg-base-300/50 rounded px-1 -mx-1 py-0.5 transition-colors">
          <code class="text-xs text-primary shrink-0">{commit.short_hash}</code>
          <span class="truncate">{commit.subject}</span>
          <span class="text-xs text-base-content/40 shrink-0 ml-auto whitespace-nowrap">{format_commit_date(commit.date)}</span>
        </button>
        <div :if={@expanded_commit == commit.hash && @commit_detail} class="ml-6 mt-1 mb-2 text-xs space-y-2">
          <pre :if={@commit_detail.body != ""} class="whitespace-pre-wrap text-base-content/70">{@commit_detail.body}</pre>
          <pre :if={@commit_detail.stat != ""} class="whitespace-pre-wrap text-base-content/50 font-mono">{@commit_detail.stat}</pre>
        </div>
      </li>
    </ul>
  </div>

  <div :if={@todos != [] && @show_todos} class="mb-2 bg-base-200 rounded-lg px-3 py-2">
    <ul class="space-y-1">
      <li :for={todo <- @todos} class="flex items-start gap-2 text-sm">
        <.icon :if={todo["status"] == "completed"} name="hero-check-circle-solid" class="size-4 text-success shrink-0 mt-0.5" />
        <.icon :if={todo["status"] == "in_progress"} name="hero-arrow-path" class="size-4 text-warning shrink-0 mt-0.5" />
        <.icon :if={todo["status"] == "pending"} name="hero-ellipsis-horizontal-circle" class="size-4 text-base-content/30 shrink-0 mt-0.5" />
        <span class={[todo["status"] == "completed" && "line-through text-base-content/50"]}>
          {todo["content"]}
        </span>
      </li>
    </ul>
  </div>


  <%!-- MCP servers modal --%>
  <div :if={@show_mcp_modal} class="fixed inset-0 z-50 flex items-end sm:items-center justify-center bg-black/50">
    <div class="card bg-base-100 shadow-xl w-full max-w-lg p-4 sm:p-6 rounded-b-none sm:rounded-b-2xl max-h-[80vh] overflow-y-auto">
      <div>
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-lg font-semibold">Session MCP Servers</h2>
          <button phx-click="toggle_mcp_modal" class="btn btn-ghost btn-sm btn-circle">
            <.icon name="hero-x-mark" class="size-5" />
          </button>
        </div>

        <p class="text-sm text-base-content/60 mb-4">
          These servers will be added to this session's MCP config on the next run, in addition to global and project-level servers.
        </p>

        <div :if={@session_mcp_servers != []} class="bg-base-200 rounded-lg divide-y divide-base-300 overflow-hidden mb-4">
          <div :for={server <- @session_mcp_servers} class="flex items-center gap-3 px-3 py-2 text-sm">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="font-medium">{server.name}</span>
                <span class={["badge badge-xs", if(server.enabled, do: "badge-success", else: "badge-ghost")]}>
                  {if server.enabled, do: "enabled", else: "disabled"}
                </span>
              </div>
              <div class="text-base-content/50 text-xs font-mono truncate">{server.url}</div>
            </div>
            <button
              phx-click="remove_mcp_server"
              phx-value-id={server.id}
              class="btn btn-xs btn-ghost text-error"
              title="Remove"
            >
              <.icon name="hero-x-mark-micro" class="size-4" />
            </button>
          </div>
        </div>

        <div :if={@session_mcp_servers == [] && !@show_mcp_server_picker} class="text-sm text-base-content/50 text-center py-4 mb-4">
          No session-specific MCP servers.
        </div>

        <div :if={!@show_mcp_server_picker} class="flex justify-between items-center">
          <.link navigate={~p"/settings"} class="link text-sm text-base-content/50">Manage server definitions</.link>
          <button phx-click="toggle_mcp_server_picker" class="btn btn-sm btn-primary">Add Server</button>
        </div>

        <div :if={@show_mcp_server_picker} class="mt-2">
          <h4 class="font-semibold text-sm mb-2">Add MCP Server</h4>
          <div :if={@all_upstream_servers == []} class="text-sm text-base-content/50">
            No servers defined. <.link navigate={~p"/settings"} class="link">Add one in Settings</.link>.
          </div>
          <div :if={@all_upstream_servers != []} class="space-y-2">
            <div :for={server <- @all_upstream_servers} class="flex items-center justify-between text-sm bg-base-200 rounded px-3 py-2">
              <div class="min-w-0 flex-1">
                <span class="font-medium">{server.name}</span>
                <span class={["badge badge-xs ml-2", if(server.enabled, do: "badge-success", else: "badge-ghost")]}>
                  {if server.enabled, do: "enabled", else: "disabled"}
                </span>
                <div class="text-base-content/50 text-xs font-mono truncate">{server.url}</div>
              </div>
              <div class="shrink-0 ml-2">
                <span :if={UpstreamServers.server_in_session?(@session.id, server.id)} class="text-xs text-base-content/40">added</span>
                <button
                  :if={!UpstreamServers.server_in_session?(@session.id, server.id)}
                  phx-click="add_mcp_server"
                  phx-value-id={server.id}
                  class="btn btn-xs btn-primary"
                >
                  Add
                </button>
              </div>
            </div>
          </div>
          <div class="flex justify-end mt-3">
            <button phx-click="toggle_mcp_server_picker" class="btn btn-sm">Cancel</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%!-- Main content area: side-by-side on desktop when files are open --%>
  <div class="flex flex-1 min-h-0 gap-4" id="session-split-container">
    <%!-- Chat column --%>
    <div class="flex flex-col min-w-0 flex-1" data-resize-panel="left">
      <div id="message-feed" phx-hook="ScrollToBottom" class="flex-1 overflow-y-auto space-y-1 p-4 bg-base-200 rounded-lg text-sm">
        <MessageComponents.message_feed messages={@messages} />
      </div>

      <div :if={@plan_mode == :review} class="mt-2 card bg-warning/10 border border-warning/30">
        <div class="card-body p-3 gap-2">
          <div class="flex items-center gap-2">
            <span class="badge badge-warning badge-sm">Plan Review</span>
            <span class="text-sm text-base-content/70">Claude has proposed a plan. Review it in the editor, make edits, then approve or provide feedback.</span>
          </div>
          <div class="flex gap-2">
            <button phx-click="approve_plan" class="btn btn-sm btn-success">
              <.icon name="hero-check-micro" class="size-4" /> Approve Plan
            </button>
            <button phx-click="reject_plan" class="btn btn-sm btn-ghost">
              <.icon name="hero-x-mark-micro" class="size-4" /> Dismiss
            </button>
          </div>
        </div>
      </div>

      <div :for={request <- @feedback_requests} class="mt-2 card bg-info/10 border border-info/30">
        <div class="card-body p-3 gap-2">
          <div class="flex items-center gap-2">
            <span class="badge badge-info badge-sm">Feedback</span>
          </div>
          <div class="text-sm bg-base-200 rounded-lg p-3">{request.question}</div>
          <div class="flex gap-2">
            <button phx-click="approve_feedback" phx-value-id={request.id} class="btn btn-sm btn-success">
              <.icon name="hero-hand-thumb-up-micro" class="size-4" /> Yes
            </button>
            <button phx-click="cancel_feedback" phx-value-id={request.id} class="btn btn-sm btn-ghost">
              <.icon name="hero-x-mark-micro" class="size-4" /> Cancel
            </button>
          </div>
          <.form for={%{}} phx-submit="respond_feedback" class="flex gap-2">
            <input type="hidden" name="feedback_id" value={request.id} />
            <textarea
              name="response"
              placeholder="Type your response..."
              class="textarea textarea-bordered flex-1 min-w-0 resize-none overflow-hidden leading-normal"
              rows="1"
              phx-hook="AutoResize"
              id={"feedback-response-#{request.id}"}
            ></textarea>
            <.button type="submit">Respond</.button>
          </.form>
        </div>
      </div>

      <div class="mt-2 sm:mt-4 flex flex-col gap-2">
        <%!-- Upload previews --%>
        <div :for={entry <- @uploads.image.entries} class="flex items-center gap-2 px-2">
          <.live_img_preview entry={entry} class="h-16 w-16 object-cover rounded" />
          <span class="text-xs truncate flex-1">{entry.client_name}</span>
          <progress :if={entry.progress < 100} value={entry.progress} max="100" class="progress progress-primary w-16 h-2" />
          <p :for={err <- upload_errors(@uploads.image, entry)} class="text-xs text-error">
            {upload_error_to_string(err)}
          </p>
          <button type="button" phx-click="cancel-upload" phx-value-ref={entry.ref} phx-value-upload="image" class="btn btn-ghost btn-xs">
            &times;
          </button>
        </div>
        <div :for={entry <- @uploads.file.entries} class="flex items-center gap-2 px-2">
          <.icon name="hero-document" class="size-8 opacity-50" />
          <span class="text-xs truncate flex-1">{entry.client_name}</span>
          <progress :if={entry.progress < 100} value={entry.progress} max="100" class="progress progress-primary w-16 h-2" />
          <p :for={err <- upload_errors(@uploads.file, entry)} class="text-xs text-error">
            {upload_error_to_string(err)}
          </p>
          <button type="button" phx-click="cancel-upload" phx-value-ref={entry.ref} phx-value-upload="file" class="btn btn-ghost btn-xs">
            &times;
          </button>
        </div>
        <%!-- Upload errors --%>
        <p :for={err <- upload_errors(@uploads.image)} class="text-xs text-error px-2">
          {upload_error_to_string(err)}
        </p>
        <p :for={err <- upload_errors(@uploads.file)} class="text-xs text-error px-2">
          {upload_error_to_string(err)}
        </p>

        <.form for={%{}} phx-submit="send_message" phx-change="validate" class="flex gap-2" multipart>
          <button type="button" phx-click="toggle_tts" class={["btn btn-ghost btn-square", @tts_autoplay && "text-primary"]} title={if @tts_autoplay, do: "Disable TTS autoplay", else: "Enable TTS autoplay"}>
            <.icon name="hero-speaker-wave" class="size-5" />
          </button>
          <div class="dropdown dropdown-top">
            <div tabindex="0" role="button" class="btn btn-ghost btn-square">
              <.icon name="hero-plus" class="size-5" />
            </div>
            <ul tabindex="0" class="dropdown-content menu bg-base-300 rounded-box z-10 w-52 p-2 shadow-lg mb-2">
              <li>
                <label>
                  <.live_file_input upload={@uploads.image} class="hidden" />
                  <.icon name="hero-photo" class="size-5" /> Upload image
                </label>
              </li>
              <li>
                <label>
                  <.live_file_input upload={@uploads.file} class="hidden" />
                  <.icon name="hero-paper-clip" class="size-5" /> Attach file
                </label>
              </li>
              <li>
                <button type="button" phx-click="commit">
                  <.icon name="hero-check" class="size-5" /> Commit
                </button>
              </li>
              <li>
                <button type="button" phx-click="new_session">
                  <.icon name="hero-plus-circle" class="size-5" /> New session
                </button>
              </li>
            </ul>
          </div>
          <div class="flex-1 min-w-0" id="prompt-wrapper" phx-update="ignore">
            <textarea
              name="prompt"
              placeholder="Send a message..."
              class="textarea textarea-bordered w-full resize-none overflow-y-auto leading-normal max-h-[7.5rem]"
              autofocus
              rows="1"
              phx-hook="AutoResize"
              id="prompt-input"
            ></textarea>
          </div>
          <button :if={@status in [:running, :compacting]} type="button" phx-click="interrupt" class="btn btn-error btn-square" title="Interrupt">
            <.icon name="hero-stop" class="size-5" />
          </button>
          <.button type="submit">
            Send
          </.button>
        </.form>
      </div>
    </div>

    <%!-- Resize handle (between chat and side panel) --%>
    <div
      :if={(@show_terminal && @open_terminals != []) || @open_files != [] || @show_file_browser}
      class="hidden lg:flex items-center justify-center w-2 cursor-col-resize group shrink-0 -mx-1 px-1 z-10"
      id="resize-handle"
      phx-hook="ResizeHandle"
    >
      <div class="flex flex-col gap-1 items-center py-2 opacity-30 group-hover:opacity-60 group-active:opacity-100 transition-opacity">
        <div class="w-1 h-1 rounded-full bg-base-content"></div>
        <div class="w-1 h-1 rounded-full bg-base-content"></div>
        <div class="w-1 h-1 rounded-full bg-base-content"></div>
        <div class="w-1 h-1 rounded-full bg-base-content"></div>
        <div class="w-1 h-1 rounded-full bg-base-content"></div>
      </div>
    </div>

    <%!-- Terminal panel column (desktop only) --%>
    <div :if={@show_terminal && @open_terminals != []} class="hidden lg:flex flex-col min-w-0 w-1/2" data-resize-panel="right">
      <%!-- Tab bar --%>
      <div class="flex items-center gap-1 mb-2">
        <div class="flex-1 flex items-center gap-1 overflow-x-auto min-w-0">
          <button
            :for={term <- @open_terminals}
            phx-click="switch_terminal"
            phx-value-id={term.id}
            class={[
              "btn btn-xs gap-1 shrink-0",
              term.id == @active_terminal_id && "btn-primary",
              term.id != @active_terminal_id && "btn-ghost"
            ]}
          >
            <span class="truncate max-w-24">{term.name}</span>
            <span phx-click="close_terminal_tab" phx-value-id={term.id} class="hover:text-error" title="Close">
              &times;
            </span>
          </button>
        </div>
        <button phx-click="new_terminal" class="btn btn-ghost btn-xs btn-circle" title="New terminal">
          <.icon name="hero-plus-micro" class="size-4" />
        </button>
        <button :if={@active_terminal_id} phx-click="pop_out_terminal" class="btn btn-ghost btn-xs btn-circle" title="Open in full page">
          <.icon name="hero-arrow-top-right-on-square-micro" class="size-4" />
        </button>
        <button phx-click="close_terminal_panel" class="btn btn-ghost btn-xs btn-circle" title="Close panel">
          <.icon name="hero-x-mark-micro" class="size-4" />
        </button>
      </div>
      <%!-- Terminal instances (all stay in DOM, only active is visible) --%>
      <div class="flex-1 min-h-0 relative">
        <div
          :for={term <- @open_terminals}
          id={"terminal-#{term.id}"}
          phx-hook="Terminal"
          data-terminal-id={term.id}
          class={[
            "absolute inset-0 rounded-lg overflow-hidden",
            term.id != @active_terminal_id && "invisible"
          ]}
          phx-update="ignore"
        >
        </div>
      </div>
    </div>

    <%!-- File panel column (desktop: side-by-side, mobile: modal) --%>
    <div :if={@open_files != [] || @show_file_browser} class="hidden lg:flex flex-col min-w-0 w-1/2" data-resize-panel="right">
      <%!-- Tab bar --%>
      <div class="flex items-center gap-1 mb-2">
        <div class="flex-1 flex items-center gap-1 overflow-x-auto min-w-0">
          <button
            :for={tab <- @open_files}
            phx-click="switch_tab"
            phx-value-path={tab.path}
            class={[
              "btn btn-xs gap-1 shrink-0",
              tab.path == @active_file_tab && "btn-primary",
              tab.path != @active_file_tab && "btn-ghost"
            ]}
          >
            <span class="font-mono truncate max-w-32">{Path.basename(tab.path)}</span>
            <span phx-click="close_tab" phx-value-path={tab.path} class="hover:text-error" title="Close">
              &times;
            </span>
          </button>
        </div>
        <button phx-click="toggle_file_browser" class={["btn btn-ghost btn-xs btn-circle", @show_file_browser && "text-primary"]} title="Browse files">
          <.icon name="hero-plus-micro" class="size-4" />
        </button>
        <button phx-click="close_file_panel" class="btn btn-ghost btn-xs btn-circle" title="Close panel">
          <.icon name="hero-x-mark-micro" class="size-4" />
        </button>
      </div>

      <div class="flex flex-1 min-h-0 gap-2">
        <%!-- File browser sidebar --%>
        <div :if={@show_file_browser} class="w-52 shrink-0 flex flex-col min-h-0 overflow-hidden">
          <div class="flex items-center gap-1 mb-1 shrink-0">
            <input
              type="text"
              placeholder="Search files..."
              value={@file_tree_filter}
              phx-keyup="filter_file_tree"
              phx-debounce="150"
              class="input input-xs input-bordered flex-1 min-w-0"
            />
            <button phx-click={JS.dispatch("phx:expand-all", to: "#session-file-tree")} class="btn btn-ghost btn-xs" title="Expand all">
              <.icon name="hero-chevron-down-micro" class="size-3" />
            </button>
            <button phx-click={JS.dispatch("phx:collapse-all", to: "#session-file-tree")} class="btn btn-ghost btn-xs" title="Collapse all">
              <.icon name="hero-chevron-up-micro" class="size-3" />
            </button>
          </div>
          <div class="flex-1 overflow-y-auto overflow-x-hidden min-h-0">
            <ul id="session-file-tree" class="menu menu-xs bg-base-200 rounded-lg w-full" phx-hook="FileTree" data-filter={@file_tree_filter}>
              <.file_tree_node :for={node <- @filtered_file_tree} node={node} />
            </ul>
          </div>
        </div>

        <%!-- File content area --%>
        <div class="flex-1 min-w-0 overflow-y-auto bg-base-200 rounded-lg p-4">
          <%= if tab = Enum.find(@open_files, & &1.path == @active_file_tab) do %>
            <%!-- File header --%>
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center gap-2 min-w-0">
                <span class="font-mono text-xs text-base-content/70 truncate">{tab.path}</span>
                <span :if={tab.read_only} class="badge badge-xs badge-ghost">read-only</span>
              </div>
              <div :if={!tab.read_only} class="flex items-center gap-1 shrink-0">
                <button
                  :if={!@file_editing && @file_edit_mode}
                  phx-click="edit_file"
                  class="btn btn-xs btn-ghost"
                >
                  Raw Edit
                </button>
                <button
                  phx-click="toggle_edit_mode"
                  class={["btn btn-xs", @file_edit_mode && "btn-primary", !@file_edit_mode && "btn-ghost"]}
                >
                  <.icon name="hero-pencil-micro" class="size-3" />
                  Edit
                </button>
              </div>
            </div>

            <%!-- Markdown block view --%>
            <div
              :if={!@file_editing && tab.blocks != []}
              id="file-blocks-desktop"
              phx-hook="ScrollToLine"
              data-line={@scroll_to_block}
            >
              <div
                :for={{index, block_text} <- tab.blocks}
                id={"file-block-#{index}"}
                class={["group relative", @scroll_to_block == index && "ring-2 ring-warning/50 rounded"]}
              >
                <div :if={@editing_block == index && @file_edit_mode} class="my-2">
                  <form phx-submit="save_block" class="space-y-2">
                    <textarea
                      name="content"
                      class="textarea textarea-bordered w-full font-mono text-sm"
                      rows={max(3, length(String.split(block_text, "\n")) + 1)}
                      phx-hook="AutoFocus"
                      id={"block-editor-#{index}"}
                    >{@block_edit_content}</textarea>
                    <div class="flex justify-end gap-2">
                      <button type="button" phx-click="cancel_block_edit" class="btn btn-xs">Cancel</button>
                      <button type="submit" class="btn btn-xs btn-primary">Save</button>
                    </div>
                  </form>
                </div>
                <div :if={@editing_block != index || !@file_edit_mode} class="relative group">
                  <div
                    phx-click={if @file_edit_mode, do: "edit_block"}
                    phx-value-index={if @file_edit_mode, do: index}
                    class={["prose prose-sm max-w-none rounded px-2 -mx-2 py-1", @file_edit_mode && "cursor-pointer hover:bg-base-300/50 transition-colors"]}
                  >
                    {Markdown.render_block(block_text)}
                  </div>
                  <button
                    :if={@file_edit_mode}
                    phx-click="delete_block"
                    phx-value-index={index}
                    class="absolute top-1 right-1 btn btn-ghost btn-xs opacity-0 group-hover:opacity-100 transition-opacity text-error"
                    title="Delete block"
                  >
                    <.icon name="hero-trash-micro" class="size-3" />
                  </button>
                </div>
              </div>
            </div>

            <%!-- Non-markdown view with line numbers --%>
            <div
              :if={!@file_editing && tab.blocks == []}
              id="file-content-desktop"
              phx-hook="ScrollToLine"
              data-line={@scroll_to_line}
            >
              <table class="text-sm font-mono w-full border-collapse">
                <tbody>
                  <tr
                    :for={{line_text, idx} <- Enum.with_index(String.split(tab.content, "\n"), 1)}
                    id={"file-line-#{idx}"}
                    class={if @scroll_to_line == idx, do: "bg-warning/20", else: ""}
                  >
                    <td class="select-none text-right pr-3 text-base-content/30 align-top w-1 whitespace-nowrap">{idx}</td>
                    <td class="whitespace-pre-wrap break-words">{line_text}</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <%!-- Raw edit mode --%>
            <div :if={@file_editing} class="space-y-3">
              <form phx-submit="save_file" class="space-y-3">
                <textarea
                  name="content"
                  class="textarea textarea-bordered w-full font-mono text-sm"
                  rows="20"
                >{tab.content}</textarea>
                <div class="flex justify-end gap-2">
                  <button type="button" phx-click="cancel_edit_file" class="btn btn-sm">Cancel</button>
                  <.button type="submit" class="btn-sm">Save</.button>
                </div>
              </form>
            </div>
          <% else %>
            <div :if={@open_files == []} class="text-sm text-base-content/50 p-8 text-center">
              Select a file to view its contents.
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%!-- Mobile file panel (modal) --%>
  <div :if={@open_files != [] || @show_file_browser} class="lg:hidden">
    <input type="checkbox" id="file-panel-modal" class="modal-toggle" checked />
    <div class="modal modal-bottom" role="dialog">
      <div class="modal-box h-[80vh] max-h-[80vh] flex flex-col p-4">
        <%!-- Modal header with tabs --%>
        <div class="flex items-center gap-1 mb-2 shrink-0">
          <div class="flex-1 flex items-center gap-1 overflow-x-auto min-w-0">
            <button
              :for={tab <- @open_files}
              phx-click="switch_tab"
              phx-value-path={tab.path}
              class={[
                "btn btn-xs gap-1 shrink-0",
                tab.path == @active_file_tab && "btn-primary",
                tab.path != @active_file_tab && "btn-ghost"
              ]}
            >
              <span class="font-mono truncate max-w-32">{Path.basename(tab.path)}</span>
              <span phx-click="close_tab" phx-value-path={tab.path} class="hover:text-error">&times;</span>
            </button>
          </div>
          <button phx-click="toggle_file_browser" class={["btn btn-ghost btn-xs btn-circle", @show_file_browser && "text-primary"]} title="Browse files">
            <.icon name="hero-plus-micro" class="size-4" />
          </button>
          <button phx-click="close_file_panel" class="btn btn-ghost btn-xs btn-circle" title="Close">
            <.icon name="hero-x-mark-micro" class="size-4" />
          </button>
        </div>

        <div class="flex flex-1 min-h-0 gap-2">
          <%!-- File browser --%>
          <div :if={@show_file_browser} class="w-44 shrink-0 flex flex-col min-h-0 overflow-hidden">
            <div class="flex items-center gap-1 mb-1 shrink-0">
              <input
                type="text"
                placeholder="Search..."
                value={@file_tree_filter}
                phx-keyup="filter_file_tree"
                phx-debounce="150"
                class="input input-xs input-bordered flex-1 min-w-0"
              />
              <button phx-click={JS.dispatch("phx:expand-all", to: "#mobile-file-tree")} class="btn btn-ghost btn-xs" title="Expand all">
                <.icon name="hero-chevron-down-micro" class="size-3" />
              </button>
              <button phx-click={JS.dispatch("phx:collapse-all", to: "#mobile-file-tree")} class="btn btn-ghost btn-xs" title="Collapse all">
                <.icon name="hero-chevron-up-micro" class="size-3" />
              </button>
            </div>
            <div class="flex-1 overflow-y-auto overflow-x-hidden min-h-0">
              <ul id="mobile-file-tree" class="menu menu-xs bg-base-200 rounded-lg w-full" phx-hook="FileTree" data-filter={@file_tree_filter}>
                <.file_tree_node :for={node <- @filtered_file_tree} node={node} />
              </ul>
            </div>
          </div>

          <%!-- File content --%>
          <div class="flex-1 min-w-0 overflow-y-auto bg-base-200 rounded-lg p-3">
            <%= if tab = Enum.find(@open_files, & &1.path == @active_file_tab) do %>
              <div class="flex items-center justify-between mb-2">
                <div class="flex items-center gap-2 min-w-0">
                  <span class="font-mono text-xs text-base-content/70 truncate">{tab.path}</span>
                  <span :if={tab.read_only} class="badge badge-xs badge-ghost">read-only</span>
                </div>
                <div :if={!tab.read_only} class="flex items-center gap-1 shrink-0">
                  <button
                    :if={!@file_editing && @file_edit_mode}
                    phx-click="edit_file"
                    class="btn btn-xs btn-ghost"
                  >
                    Raw Edit
                  </button>
                  <button
                    phx-click="toggle_edit_mode"
                    class={["btn btn-xs", @file_edit_mode && "btn-primary", !@file_edit_mode && "btn-ghost"]}
                  >
                    <.icon name="hero-pencil-micro" class="size-3" />
                    Edit
                  </button>
                </div>
              </div>

              <div
                :if={!@file_editing && tab.blocks != []}
                id="file-blocks-mobile"
                phx-hook="ScrollToLine"
                data-line={@scroll_to_block}
              >
                <div
                  :for={{index, block_text} <- tab.blocks}
                  id={"mobile-file-block-#{index}"}
                  class={["group relative", @scroll_to_block == index && "ring-2 ring-warning/50 rounded"]}
                >
                  <div :if={@editing_block == index && @file_edit_mode} class="my-2">
                    <form phx-submit="save_block" class="space-y-2">
                      <textarea
                        name="content"
                        class="textarea textarea-bordered w-full font-mono text-sm"
                        rows={max(3, length(String.split(block_text, "\n")) + 1)}
                        phx-hook="AutoFocus"
                        id={"mobile-block-editor-#{index}"}
                      >{@block_edit_content}</textarea>
                      <div class="flex justify-end gap-2">
                        <button type="button" phx-click="cancel_block_edit" class="btn btn-xs">Cancel</button>
                        <button type="submit" class="btn btn-xs btn-primary">Save</button>
                      </div>
                    </form>
                  </div>
                  <div :if={@editing_block != index || !@file_edit_mode}>
                    <div
                      phx-click={if @file_edit_mode, do: "edit_block"}
                      phx-value-index={if @file_edit_mode, do: index}
                      class={["prose prose-sm max-w-none rounded px-2 -mx-2 py-1", @file_edit_mode && "cursor-pointer hover:bg-base-300/50"]}
                    >
                      {Markdown.render_block(block_text)}
                    </div>
                  </div>
                </div>
              </div>

              <div
                :if={!@file_editing && tab.blocks == []}
                id="file-content-mobile"
                phx-hook="ScrollToLine"
                data-line={@scroll_to_line}
              >
                <table class="text-sm font-mono w-full border-collapse">
                  <tbody>
                    <tr
                      :for={{line_text, idx} <- Enum.with_index(String.split(tab.content, "\n"), 1)}
                      id={"mobile-file-line-#{idx}"}
                      class={if @scroll_to_line == idx, do: "bg-warning/20", else: ""}
                    >
                      <td class="select-none text-right pr-3 text-base-content/30 align-top w-1 whitespace-nowrap">{idx}</td>
                      <td class="whitespace-pre-wrap break-words">{line_text}</td>
                    </tr>
                  </tbody>
                </table>
              </div>

              <div :if={@file_editing} class="space-y-3">
                <form phx-submit="save_file" class="space-y-3">
                  <textarea
                    name="content"
                    class="textarea textarea-bordered w-full font-mono text-sm"
                    rows="15"
                  >{tab.content}</textarea>
                  <div class="flex justify-end gap-2">
                    <button type="button" phx-click="cancel_edit_file" class="btn btn-sm">Cancel</button>
                    <.button type="submit" class="btn-sm">Save</.button>
                  </div>
                </form>
              </div>
            <% else %>
              <div :if={@open_files == []} class="text-sm text-base-content/50 p-4 text-center">
                Select a file to view.
              </div>
            <% end %>
          </div>
        </div>
      </div>
      <label class="modal-backdrop" phx-click="close_file_panel"></label>
    </div>
  </div>
</div>
