<.header>
  Settings
</.header>

<div class="mt-8">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-semibold">MCP Servers</h3>
    <div class="flex gap-2">
      <button
        phx-click="refresh_connections"
        class="btn btn-sm btn-ghost"
        title="Refresh connections"
      >
        <.icon name="hero-arrow-path-micro" class="size-4" />
      </button>
      <.link patch={~p"/settings/upstream/new"}>
        <.button class="btn-sm">Add Server</.button>
      </.link>
    </div>
  </div>

  <p class="text-sm text-base-content/60 mb-4">
    Define MCP servers here and add them to specific projects or sessions from their pages.
    Servers marked as <strong>global</strong>
    are also aggregated into OrcaHub's MCP endpoint and available to every session automatically.
    Tools from global servers are namespaced with a prefix to avoid conflicts.
  </p>

  <div :if={@show_form} class="card bg-base-200 p-4 mb-6">
    <h4 class="font-semibold mb-3">
      {if @editing_server, do: "Edit Server", else: "Add MCP Server"}
    </h4>
    <.form for={@form} phx-submit="save" phx-change="validate" class="space-y-3">
      <.input
        field={@form[:name]}
        type="text"
        label="Name"
        placeholder="My MCP Server"
        phx-debounce="blur"
      />
      <.input
        field={@form[:url]}
        type="text"
        label="URL"
        placeholder="https://example.com/mcp"
        phx-debounce="blur"
      />
      <.input
        field={@form[:prefix]}
        type="text"
        label="Tool prefix"
        placeholder="Auto-generated from name"
        phx-debounce="blur"
      />
      <p class="text-xs text-base-content/50 -mt-2">
        Tools will be exposed as <code class="bg-base-300 px-1 rounded">prefix__tool_name</code>
      </p>
      <.input field={@form[:global]} type="checkbox" label="Available to all sessions (global)" />
      <p class="text-xs text-base-content/50 -mt-2">
        When enabled, this server is automatically included in every session via OrcaHub's MCP proxy.
        Uncheck to only use this server in specific projects or sessions.
      </p>
      <.input
        field={@form[:session_scoped]}
        type="checkbox"
        label="Separate upstream session per Orca session"
      />
      <p class="text-xs text-base-content/50 -mt-2">
        For stateful servers (e.g. Playwright): each Orca session gets its own upstream MCP
        session — its own browser context — instead of sharing one.
      </p>
      <.input
        field={@form[:secret_injection]}
        type="checkbox"
        label="Inject OrcaHub secrets into calls to this server"
      />
      <p class="text-xs text-base-content/50 -mt-2">
        When enabled, any argument value that exactly matches a secret key name (see
        <strong>Secrets</strong>
        below) is replaced with the real value before the call is forwarded upstream, and
        every occurrence of a secret value (plus common encodings) is masked out of this
        server's tool responses.
      </p>

      <div>
        <label class="label"><span class="label-text">Headers</span></label>
        <p class="text-xs text-base-content/50 mb-2">
          Add authentication headers or other custom headers for the upstream server.
        </p>
        <div class="space-y-2">
          <div
            :for={{pair, idx} <- Enum.with_index(@header_pairs)}
            class="flex items-center gap-2"
          >
            <input
              type="text"
              name={"header_keys[#{idx}]"}
              value={pair.key}
              placeholder="Header name"
              phx-debounce="blur"
              class="input input-sm input-bordered flex-1"
            />
            <input
              type="text"
              name={"header_values[#{idx}]"}
              value={pair.value}
              placeholder="Header value"
              phx-debounce="blur"
              class="input input-sm input-bordered flex-1"
            />
            <button
              type="button"
              phx-click="remove_header"
              phx-value-index={idx}
              class="btn btn-sm btn-ghost text-error"
            >
              <.icon name="hero-x-mark-micro" class="size-4" />
            </button>
          </div>
        </div>
        <button type="button" phx-click="add_header" class="btn btn-xs btn-ghost mt-2">
          + Add header
        </button>
      </div>

      <div class="flex justify-end gap-2 mt-4">
        <.link patch={~p"/settings"} class="btn btn-sm">Cancel</.link>
        <.button type="submit" class="btn-sm">
          {if @editing_server, do: "Update", else: "Add"}
        </.button>
      </div>
    </.form>
  </div>

  <div
    :if={@servers == [] && !@show_form}
    class="text-sm text-base-content/50 p-8 text-center bg-base-200 rounded-lg"
  >
    No MCP servers configured.
  </div>

  <div
    :if={@servers != []}
    class="bg-base-200 rounded-lg divide-y divide-base-300 overflow-hidden"
  >
    <div
      :for={server <- @servers}
      class="flex items-center gap-3 px-4 py-3 text-sm hover:bg-base-300/50"
    >
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2">
          <span class="font-medium">{server.name}</span>
          <span class={[
            "badge badge-xs",
            if(server.enabled, do: "badge-success", else: "badge-ghost")
          ]}>
            {if server.enabled, do: "enabled", else: "disabled"}
          </span>
          <span :if={server.global} class="badge badge-xs badge-neutral">global</span>
          <span :if={server.session_scoped} class="badge badge-xs badge-accent">
            session-scoped
          </span>
          <span
            :if={server.secret_injection}
            class="badge badge-xs badge-warning gap-1"
            title="OrcaHub secrets are injected into calls and masked from responses"
          >
            <.icon name="hero-key-micro" class="size-3" /> secret injection
          </span>
          <span :if={server.enabled && server.global} class="badge badge-xs badge-info">
            {tool_count_for_server(@upstream_tools, server)} tools
          </span>
        </div>
        <div class="text-base-content/50 text-xs mt-0.5 font-mono truncate">{server.url}</div>
        <div class="text-base-content/40 text-xs mt-0.5">
          Prefix: <code class="bg-base-300 px-1 rounded">{server.prefix}</code>
        </div>
      </div>
      <div class="flex items-center gap-1">
        <button
          phx-click="toggle"
          phx-value-id={server.id}
          class="btn btn-xs btn-ghost"
          title={if server.enabled, do: "Disable", else: "Enable"}
        >
          <.icon
            name={if server.enabled, do: "hero-pause-micro", else: "hero-play-micro"}
            class="size-4"
          />
        </button>
        <button
          phx-click="toggle_global"
          phx-value-id={server.id}
          class="btn btn-xs btn-ghost"
          title={if server.global, do: "Make project/session-only", else: "Make global"}
        >
          <.icon
            name={if server.global, do: "hero-globe-alt-micro", else: "hero-lock-closed-micro"}
            class="size-4"
          />
        </button>
        <.link
          patch={~p"/settings/upstream/#{server.id}/edit"}
          class="btn btn-xs btn-ghost"
          title="Edit"
        >
          <.icon name="hero-pencil-micro" class="size-4" />
        </.link>
        <button
          phx-click="delete"
          phx-value-id={server.id}
          data-confirm="Remove this upstream server?"
          class="btn btn-xs btn-ghost text-error"
          title="Delete"
        >
          <.icon name="hero-trash-micro" class="size-4" />
        </button>
      </div>
    </div>
  </div>

  <div :if={@upstream_tools != []} class="mt-6">
    <h4 class="text-sm font-semibold text-base-content/70 mb-2">
      Aggregated Tools ({length(@upstream_tools)})
    </h4>
    <div class="bg-base-200 rounded-lg divide-y divide-base-300 overflow-hidden">
      <div :for={tool <- @upstream_tools} class="px-4 py-2 text-sm">
        <div class="font-mono text-xs">{tool["name"]}</div>
        <div class="text-base-content/50 text-xs truncate">{tool["description"]}</div>
      </div>
    </div>
  </div>
</div>

<div class="mt-10">
  <h3 class="text-lg font-semibold mb-4">Secrets</h3>

  <p class="text-sm text-base-content/60 mb-4">
    Secrets stored here can be injected into calls to upstream servers with
    <strong>secret injection</strong>
    enabled above (e.g. Playwright). Pass the key name as a literal argument value — the
    real value is substituted server-side and never sent to or returned by the agent.
    Values are <strong>write-only</strong>: once saved, they cannot be viewed again here.
  </p>

  <form phx-submit="add_secret" class="card bg-base-200 p-4 mb-4 flex-row items-end gap-2">
    <div class="flex-1">
      <label class="label"><span class="label-text">Key</span></label>
      <input
        type="text"
        name="key"
        placeholder="PHX_AGENT_PASSWORD"
        autocomplete="off"
        class="input input-sm input-bordered w-full font-mono"
      />
    </div>
    <div class="flex-1">
      <label class="label"><span class="label-text">Value</span></label>
      <input
        type="password"
        name="value"
        autocomplete="new-password"
        class="input input-sm input-bordered w-full"
      />
    </div>
    <.button type="submit" class="btn-sm">Save</.button>
  </form>

  <div
    :if={@secret_keys == []}
    class="text-sm text-base-content/50 p-8 text-center bg-base-200 rounded-lg"
  >
    No secrets stored.
  </div>

  <div
    :if={@secret_keys != []}
    class="bg-base-200 rounded-lg divide-y divide-base-300 overflow-hidden"
  >
    <div
      :for={secret <- @secret_keys}
      class="flex items-center gap-3 px-4 py-3 text-sm hover:bg-base-300/50"
    >
      <div class="flex-1 min-w-0">
        <div class="font-mono font-medium">{secret.key}</div>
        <div class="text-base-content/50 text-xs mt-0.5">
          Updated {secret.updated_at}
        </div>
      </div>
      <button
        phx-click="delete_secret"
        phx-value-key={secret.key}
        data-confirm={"Delete secret #{secret.key}? Sessions using it will fail until it's re-added."}
        class="btn btn-xs btn-ghost text-error"
        title="Delete"
      >
        <.icon name="hero-trash-micro" class="size-4" />
      </button>
    </div>
  </div>
</div>

<div class="mt-10">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-semibold">Cluster Code Sync</h3>
    <div class="flex gap-2">
      <button phx-click="check_drift" class="btn btn-sm btn-ghost" title="Check for code drift">
        <.icon name="hero-magnifying-glass-micro" class="size-4" /> Check Drift
      </button>
      <button
        phx-click="push_changed_code"
        class="btn btn-sm btn-ghost"
        disabled={@code_sync_loading}
      >
        <.icon name="hero-arrow-up-tray-micro" class="size-4" /> Push Changed
      </button>
      <button
        phx-click="push_all_code"
        class="btn btn-sm btn-primary"
        disabled={@code_sync_loading}
      >
        <.icon name="hero-arrow-up-tray-micro" class="size-4" /> Push All
      </button>
    </div>
  </div>

  <p class="text-sm text-base-content/60 mb-4">
    Hot-load compiled beam files from this node onto remote agent nodes without restarting.
  </p>

  <div :if={@code_sync_loading} class="flex items-center gap-2 text-sm text-base-content/60 mb-4">
    <span class="loading loading-spinner loading-sm"></span> Pushing code...
  </div>

  <%!-- Result display --%>
  <div :if={@code_sync_result && !@code_sync_loading} class="mb-4">
    <div class={[
      "alert text-sm",
      if(@code_sync_result[:errors] == [], do: "alert-success", else: "alert-warning")
    ]}>
      <div>
        <div>
          Pushed <strong>{@code_sync_result.modules_pushed}</strong>
          modules
          to <strong>{@code_sync_result.nodes_updated}</strong>
          node(s).
          <%= if @code_sync_result[:skipped] do %>
            <span class="text-base-content/60">({@code_sync_result.skipped})</span>
          <% end %>
        </div>
        <div :if={@code_sync_result[:errors] != []} class="mt-1 text-xs text-error">
          <div :for={err <- @code_sync_result.errors}>{err}</div>
        </div>
      </div>
    </div>
  </div>

  <%!-- Connected nodes --%>
  <div class="bg-base-200 rounded-lg divide-y divide-base-300 overflow-hidden">
    <div class="px-4 py-2 text-xs font-semibold text-base-content/50 uppercase tracking-wide">
      Connected Nodes ({length(@cluster_nodes)})
    </div>
    <div
      :for={info <- @cluster_nodes}
      class="flex items-center gap-3 px-4 py-3 text-sm hover:bg-base-300/50"
    >
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2">
          <span class="font-medium">{info.name}</span>
          <span :if={info.node == node()} class="badge badge-xs badge-primary">this node</span>
          <span :if={info.node != node()} class="badge badge-xs badge-success">connected</span>
          <span
            :if={"#{info.node}" in @logged_in_nodes}
            class="badge badge-xs badge-info gap-1"
            title="A Claude Code OAuth token is stored for this node"
          >
            <.icon name="hero-key-micro" class="size-3" /> logged in
          </span>
          <% codex = Map.get(@codex_status_by_node, "#{info.node}", %{status: :not_logged_in}) %>
          <span
            :if={codex.status != :not_logged_in}
            class="badge badge-xs badge-secondary gap-1"
            title="Codex login status"
          >
            <.icon name="hero-key-micro" class="size-3" /> codex: {codex.label}
          </span>
          <span
            :if={Map.get(@codex_env_conflict_by_node, "#{info.node}", false)}
            class="badge badge-xs badge-warning gap-1"
            title="OPENAI_API_KEY is set on this node and will override any codex login"
          >
            <.icon name="hero-exclamation-triangle-micro" class="size-3" /> codex env conflict
          </span>
          <% pi_count = length(Map.get(@pi_providers_by_node, "#{info.node}", [])) %>
          <span
            :if={pi_count > 0}
            class="badge badge-xs badge-accent gap-1"
            title="Configured pi provider keys"
          >
            <.icon name="hero-key-micro" class="size-3" /> pi: {pi_count}
          </span>
        </div>
        <div class="text-base-content/50 text-xs mt-0.5 font-mono">{info.node}</div>
      </div>
      <div class="flex items-center gap-1 flex-wrap justify-end">
        <button
          phx-click="login_node"
          phx-value-node={info.node}
          class="btn btn-xs btn-ghost"
          title="Log this node into Claude Code"
        >
          <.icon name="hero-arrow-right-on-rectangle-micro" class="size-4" /> Claude
        </button>
        <button
          :if={"#{info.node}" in @logged_in_nodes}
          phx-click="logout_node"
          phx-value-node={info.node}
          data-confirm={"Remove the stored Claude Code token for #{info.name}?"}
          class="btn btn-xs btn-ghost text-warning"
          title="Remove stored credential"
        >
          <.icon name="hero-trash-micro" class="size-4" />
        </button>
        <button
          phx-click="codex_login_device"
          phx-value-node={info.node}
          class="btn btn-xs btn-ghost"
          title="Log this node into codex via ChatGPT device-auth"
        >
          <.icon name="hero-arrow-right-on-rectangle-micro" class="size-4" /> Codex (device)
        </button>
        <button
          phx-click="codex_login_api_key_open"
          phx-value-node={info.node}
          class="btn btn-xs btn-ghost"
          title="Set a codex API key for this node"
        >
          <.icon name="hero-key-micro" class="size-4" /> Codex (key)
        </button>
        <button
          phx-click="open_pi_keys"
          phx-value-node={info.node}
          class="btn btn-xs btn-ghost"
          title="Manage pi provider keys for this node"
        >
          <.icon name="hero-key-micro" class="size-4" /> pi keys
        </button>
        <button
          :if={info.node != node()}
          phx-click="push_to_node"
          phx-value-node={info.node}
          class="btn btn-xs btn-ghost"
          title="Push code to this node"
          disabled={@code_sync_loading}
        >
          <.icon name="hero-arrow-up-tray-micro" class="size-4" />
        </button>
        <button
          :if={info.node != node()}
          phx-click="restart_supervisor"
          phx-value-node={info.node}
          phx-value-supervisor="OrcaHub.SessionSupervisor"
          data-confirm={"Restart SessionSupervisor on #{info.name}? This will stop all running sessions on that node."}
          class="btn btn-xs btn-ghost text-warning"
          title="Restart SessionSupervisor"
        >
          <.icon name="hero-arrow-path-micro" class="size-4" />
        </button>
      </div>
    </div>
    <div :if={length(@cluster_nodes) <= 1} class="px-4 py-3 text-sm text-base-content/50">
      No remote nodes connected.
    </div>
  </div>

  <%!-- Drift check results --%>
  <div :if={@drift_results} class="mt-4">
    <h4 class="text-sm font-semibold text-base-content/70 mb-2">Code Drift Report</h4>
    <div class="bg-base-200 rounded-lg divide-y divide-base-300 overflow-hidden">
      <div :for={dr <- @drift_results} class="px-4 py-3 text-sm">
        <div class="flex items-center gap-2 mb-1">
          <span class="font-medium font-mono text-xs">{dr.node}</span>
          <span :if={dr.drifted == [] && dr.missing == []} class="badge badge-xs badge-success">
            in sync
          </span>
          <span :if={dr.drifted != [] || dr.missing != []} class="badge badge-xs badge-warning">
            {length(dr.drifted)} drifted, {length(dr.missing)} missing
          </span>
        </div>
        <div :if={dr.drifted != []} class="text-xs text-base-content/60 mt-1">
          Drifted: {dr.drifted |> Enum.map(&inspect/1) |> Enum.join(", ")}
        </div>
        <div :if={dr.missing != []} class="text-xs text-base-content/60 mt-1">
          Missing: {dr.missing |> Enum.map(&inspect/1) |> Enum.join(", ")}
        </div>
      </div>
    </div>
  </div>
</div>

<%!-- Node login flow (claude setup-token) --%>
<div
  :if={@login_node}
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
  phx-window-keydown="cancel_login"
  phx-key="escape"
>
  <div class="bg-base-100 rounded-lg shadow-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between px-5 py-3 border-b border-base-300">
      <h3 class="text-lg font-semibold">
        Log in {Cluster.node_name(@login_node)}
      </h3>
      <button phx-click="cancel_login" class="btn btn-sm btn-ghost btn-circle">
        <.icon name="hero-x-mark-micro" class="size-4" />
      </button>
    </div>

    <div class="px-5 py-4 space-y-4">
      <%= case @login_status do %>
        <% :success -> %>
          <div class="alert alert-success text-sm">
            <.icon name="hero-check-circle-micro" class="size-5" />
            <span>{Cluster.node_name(@login_node)} is now logged in to Claude Code.</span>
          </div>
        <% :error -> %>
          <div class="alert alert-error text-sm">
            <.icon name="hero-exclamation-triangle-micro" class="size-5" />
            <span>Login failed: {@login_error}</span>
          </div>
        <% _ -> %>
          <p class="text-sm text-base-content/70">
            Open the authorize URL below, sign in, then paste the resulting code here.
          </p>
      <% end %>

      <div :if={@login_url && @login_status != :success}>
        <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wide mb-1">
          Authorize URL
        </div>
        <a
          href={@login_url}
          target="_blank"
          rel="noopener"
          class="link link-primary text-sm break-all"
        >
          {@login_url}
        </a>
      </div>

      <form
        :if={@login_status not in [:success, :error]}
        phx-submit="submit_login_code"
        class="flex items-end gap-2"
      >
        <div class="flex-1">
          <label class="text-xs font-semibold text-base-content/50 uppercase tracking-wide">
            Paste code
          </label>
          <input
            type="text"
            name="code"
            autocomplete="off"
            placeholder="Paste the code from the browser"
            class="input input-bordered input-sm w-full mt-1"
          />
        </div>
        <button type="submit" class="btn btn-sm btn-primary">Submit</button>
      </form>

      <div>
        <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wide mb-1">
          Output
        </div>
        <pre class="bg-base-300 rounded p-3 text-xs overflow-x-auto max-h-64 whitespace-pre-wrap">{if @login_output == "", do: "Starting…", else: @login_output}</pre>
      </div>

      <div class="flex justify-end gap-2 pt-2">
        <button
          :if={@login_status in [:success, :error]}
          phx-click="close_login"
          class="btn btn-sm btn-primary"
        >
          Close
        </button>
        <button
          :if={@login_status not in [:success, :error]}
          phx-click="cancel_login"
          class="btn btn-sm btn-ghost"
        >
          Cancel
        </button>
      </div>
    </div>
  </div>
</div>

<%!-- Node login flow (codex device-auth / API key) --%>
<div
  :if={@codex_login_node}
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
  phx-window-keydown="cancel_codex_login"
  phx-key="escape"
>
  <div class="bg-base-100 rounded-lg shadow-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between px-5 py-3 border-b border-base-300">
      <h3 class="text-lg font-semibold">
        Log in {Cluster.node_name(@codex_login_node)} to codex
        <span class="text-sm font-normal text-base-content/50">
          ({if @codex_login_mode == :device_auth, do: "device auth", else: "API key"})
        </span>
      </h3>
      <button phx-click="cancel_codex_login" class="btn btn-sm btn-ghost btn-circle">
        <.icon name="hero-x-mark-micro" class="size-4" />
      </button>
    </div>

    <div class="px-5 py-4 space-y-4">
      <div
        :if={Map.get(@codex_env_conflict_by_node, "#{@codex_login_node}", false)}
        class="alert alert-warning text-sm"
      >
        <.icon name="hero-exclamation-triangle-micro" class="size-5" />
        <span>
          <code class="bg-base-300 px-1 rounded">OPENAI_API_KEY</code>
          is set on this node's environment and will silently override this login for codex —
          unset it there first if you want this login to actually take effect.
        </span>
      </div>

      <%= case @codex_login_status do %>
        <% :success -> %>
          <div class="alert alert-success text-sm">
            <.icon name="hero-check-circle-micro" class="size-5" />
            <span>{Cluster.node_name(@codex_login_node)} is now logged in to codex.</span>
          </div>
        <% :error -> %>
          <div class="alert alert-error text-sm">
            <.icon name="hero-exclamation-triangle-micro" class="size-5" />
            <span>Login failed: {@codex_login_error}</span>
          </div>
        <% _ -> %>
          <p :if={@codex_login_mode == :device_auth} class="text-sm text-base-content/70">
            Open the verification URL below on <strong>any</strong>
            device, sign in, and enter the code shown — no need to paste anything back here.
            Requires "device code" login to be enabled in your ChatGPT account's security
            settings first.
          </p>
          <p :if={@codex_login_mode == :api_key} class="text-sm text-base-content/70">
            Paste an OpenAI API key below. It's piped directly to
            <code class="bg-base-300 px-1 rounded">codex login --with-api-key</code>
            on the target node and is never stored, logged, or displayed by OrcaHub.
            This is API-key auth only — it does not grant ChatGPT-plan usage.
          </p>
      <% end %>

      <div :if={
        @codex_login_mode == :device_auth && @codex_login_url && @codex_login_status != :success
      }>
        <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wide mb-1">
          Verification URL
        </div>
        <a
          href={@codex_login_url}
          target="_blank"
          rel="noopener"
          class="link link-primary text-sm break-all"
        >
          {@codex_login_url}
        </a>
      </div>

      <div :if={
        @codex_login_mode == :device_auth && @codex_login_code && @codex_login_status != :success
      }>
        <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wide mb-1">
          Code
        </div>
        <div class="text-lg font-mono tracking-widest">{@codex_login_code}</div>
      </div>

      <form
        :if={
          @codex_login_mode == :api_key && @codex_login_status not in [:running, :success, :error]
        }
        phx-submit="submit_codex_api_key"
        class="flex items-end gap-2"
      >
        <div class="flex-1">
          <label class="text-xs font-semibold text-base-content/50 uppercase tracking-wide">
            API key
          </label>
          <input
            type="password"
            name="key"
            autocomplete="off"
            placeholder="sk-..."
            class="input input-bordered input-sm w-full mt-1"
          />
        </div>
        <button type="submit" class="btn btn-sm btn-primary">Log in</button>
      </form>

      <div :if={@codex_login_mode == :device_auth}>
        <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wide mb-1">
          Output
        </div>
        <pre class="bg-base-300 rounded p-3 text-xs overflow-x-auto max-h-64 whitespace-pre-wrap">{if @codex_login_output == "", do: "Starting…", else: @codex_login_output}</pre>
      </div>

      <div :if={@codex_login_mode == :api_key && @codex_login_status == :running} class="text-sm">
        <span class="loading loading-spinner loading-sm"></span>
        Running codex login --with-api-key…
      </div>

      <div class="flex justify-end gap-2 pt-2">
        <button
          :if={@codex_login_status in [:success, :error]}
          phx-click="close_codex_login"
          class="btn btn-sm btn-primary"
        >
          Close
        </button>
        <button
          :if={@codex_login_status not in [:success, :error]}
          phx-click="cancel_codex_login"
          class="btn btn-sm btn-ghost"
        >
          Cancel
        </button>
      </div>
    </div>
  </div>
</div>

<%!-- pi provider keys --%>
<div
  :if={@pi_key_node}
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
  phx-window-keydown="close_pi_keys"
  phx-key="escape"
>
  <div class="bg-base-100 rounded-lg shadow-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between px-5 py-3 border-b border-base-300">
      <h3 class="text-lg font-semibold">
        pi provider keys — {Cluster.node_name(@pi_key_node)}
      </h3>
      <button phx-click="close_pi_keys" class="btn btn-sm btn-ghost btn-circle">
        <.icon name="hero-x-mark-micro" class="size-4" />
      </button>
    </div>

    <div class="px-5 py-4 space-y-4">
      <p class="text-sm text-base-content/70">
        Keys are written directly to
        <code class="bg-base-300 px-1 rounded">~/.pi/agent/auth.json</code>
        on the target node — write-only, never displayed again here. Unlike codex (where an
        env var wins), pi prefers a stored <code class="bg-base-300 px-1 rounded">auth.json</code>
        key <strong>over</strong>
        any environment variable of the same provider.
      </p>

      <form phx-submit="save_pi_key" class="card bg-base-200 p-3 space-y-2" phx-value-provider="">
        <div class="flex items-end gap-2">
          <div class="flex-1">
            <label class="label"><span class="label-text text-xs">Provider</span></label>
            <select name="provider" class="select select-bordered select-sm w-full">
              <option :for={p <- @pi_provider_options} value={p}>{p}</option>
              <option value="custom">custom…</option>
            </select>
          </div>
          <div class="flex-1">
            <label class="label">
              <span class="label-text text-xs">Custom provider id</span>
            </label>
            <input
              type="text"
              name="custom_provider"
              placeholder="only used if 'custom' is selected"
              class="input input-sm input-bordered w-full"
            />
          </div>
        </div>
        <div class="flex items-end gap-2">
          <div class="flex-1">
            <label class="label"><span class="label-text text-xs">API key</span></label>
            <input
              type="password"
              name="key"
              autocomplete="off"
              class="input input-sm input-bordered w-full"
            />
          </div>
          <.button type="submit" class="btn-sm">Save</.button>
        </div>
      </form>

      <div
        :if={@pi_key_sanity}
        class={[
          "alert text-xs",
          if(match?({:ok, _}, @pi_key_sanity), do: "alert-success", else: "alert-warning")
        ]}
      >
        <span>{elem(@pi_key_sanity, 1)}</span>
      </div>

      <div>
        <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wide mb-1">
          Configured providers
        </div>
        <div
          :if={Map.get(@pi_providers_by_node, "#{@pi_key_node}", []) == []}
          class="text-sm text-base-content/50 p-4 text-center bg-base-200 rounded-lg"
        >
          No pi provider keys configured on this node.
        </div>
        <div
          :if={Map.get(@pi_providers_by_node, "#{@pi_key_node}", []) != []}
          class="bg-base-200 rounded-lg divide-y divide-base-300 overflow-hidden"
        >
          <div
            :for={p <- Map.get(@pi_providers_by_node, "#{@pi_key_node}", [])}
            class="flex items-center gap-3 px-3 py-2 text-sm"
          >
            <div class="flex-1">
              <span class="font-mono">{p.provider}</span>
              <span class="badge badge-xs badge-success ml-2">configured</span>
              <span :if={p.type} class="text-xs text-base-content/50 ml-1">({p.type})</span>
            </div>
            <button
              phx-click="delete_pi_key"
              phx-value-provider={p.provider}
              data-confirm={"Remove the stored #{p.provider} key on #{Cluster.node_name(@pi_key_node)}?"}
              class="btn btn-xs btn-ghost text-error"
              title="Remove"
            >
              <.icon name="hero-trash-micro" class="size-4" />
            </button>
          </div>
        </div>
      </div>

      <div class="flex justify-end pt-2">
        <button phx-click="close_pi_keys" class="btn btn-sm btn-primary">Close</button>
      </div>
    </div>
  </div>
</div>
