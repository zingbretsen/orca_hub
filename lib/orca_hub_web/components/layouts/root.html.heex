<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="OrcaHub">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <style>pre:has(> code.mermaid), pre:has(> code.language-mermaid) { visibility: hidden; height: 0; overflow: hidden; }</style>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script type="module">
      import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
      mermaid.initialize({ startOnLoad: false, theme: "dark" });

      let pending = null;
      function renderMermaidBlocks() {
        if (pending) return;
        pending = requestAnimationFrame(() => {
          pending = null;
          const nodes = [];
          document.querySelectorAll("pre > code.mermaid, pre > code.language-mermaid").forEach((codeEl) => {
            const pre = codeEl.parentElement;
            if (pre.dataset.mermaidRendered) return;
            pre.dataset.mermaidRendered = "true";

            const container = document.createElement("div");
            container.className = "mermaid";
            container.textContent = codeEl.textContent;
            pre.replaceWith(container);
            nodes.push(container);
          });
          if (nodes.length > 0) {
            mermaid.run({ nodes });
          }
        });
      }

      // Render on initial load and after LiveView DOM patches
      renderMermaidBlocks();
      new MutationObserver(renderMermaidBlocks).observe(document.body, {
        childList: true,
        subtree: true,
      });
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
