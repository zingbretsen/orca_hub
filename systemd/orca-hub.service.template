[Unit]
Description=OrcaHub (compiled OTP release)
After=network-online.target
Wants=network-online.target
StartLimitBurst=3
StartLimitIntervalSec=60

[Service]
Type=simple
User={{USER}}
WorkingDirectory={{ORCA_HUB_DIR}}
EnvironmentFile={{ORCA_HUB_DIR}}/.env
Environment="PATH={{HOME}}/.local/bin:/usr/local/bin:/usr/bin:/bin"
Environment="PHX_SERVER=true"
ExecStart={{ORCA_HUB_DIR}}/_build/prod/rel/orca_hub/bin/orca_hub start
Restart=on-failure
RestartSec=5

# Give the BEAM VM time to shut down gracefully
TimeoutStopSec=30

# Logging — stdout/stderr go to journald
StandardOutput=journal
StandardError=journal
SyslogIdentifier=orca-hub

# Basic hardening. Further hardening (ProtectSystem=strict, ProtectHome=read-only,
# ReadWritePaths=...) is deferred — the app writes to ~/.claude, project
# directories, and other paths that need careful enumeration first.
NoNewPrivileges=yes
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
